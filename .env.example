ANTHROPIC_API_KEY=sk-ant-your-key-here

# Image generation provider chain (tried in order, first success wins)
# Format: type|base_url|api_key  (comma-separated for multiple)
# Types: comfyui, openai
#
# Examples:
#   Local ComfyUI only:
#     IMAGE_PROVIDERS=comfyui|http://localhost:8188
#
#   OpenAI DALL-E only:
#     IMAGE_PROVIDERS=openai||sk-your-openai-key
#
#   ComfyUI first, fall back to OpenAI:
#     IMAGE_PROVIDERS=comfyui|http://localhost:8188,openai||sk-your-openai-key
#
# IMAGE_PROVIDERS=

# Text-to-speech provider chain (tried in order, first success wins)
# Format: type|base_url|api_key  (comma-separated for multiple)
# Types: browser (client-side, no config), openai, elevenlabs
#
# Examples:
#   Browser only (free, zero config):
#     TTS_PROVIDERS=browser
#
#   OpenAI TTS:
#     TTS_PROVIDERS=openai||sk-your-openai-key
#
#   Browser first, server fallback:
#     TTS_PROVIDERS=browser,openai||sk-your-openai-key
#
# TTS_PROVIDERS=
# TTS_VOICE=alloy          # Voice name (provider-specific)
# TTS_MODEL=tts-1          # Model name (provider-specific)
