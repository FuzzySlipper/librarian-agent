provider: anthropic
user_agent: NarrativeOrchestrator/1.0    # Sent with all API requests

models:
  librarian: claude-haiku-4-5-20251001
  prose_writer: claude-sonnet-4-6
  orchestrator: claude-sonnet-4-6

librarian:
  max_tokens_per_query: 1024

prose_writer:
  max_tokens_per_scene: 4096
  auto_append_to_story: true

persona:
  max_tokens: 2000
  # active: narrator        # Subdirectory of paths.persona to use (omit for root)

lore:
  # active: pale-city       # Subdirectory of paths.lore to use (omit for root)

writing_style:
  active: default            # Filename (without .md) in paths.writing_styles

paths:
  lore: ./build/lore
  story: ./build/story
  writing: ./build/writing
  chats: ./build/chats
  code_requests: ./docs/code-requests
  persona: ./build/persona
  writing_styles: ./build/writing-styles
  council: ./build/council
  layouts: ./build/layouts
  layout_images: ./build/layout-images
  forge_prompts: ./build/forge-prompts
  forge: ./build/forge
  portraits: ./build/portraits
  data: ./build/data
